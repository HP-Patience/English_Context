# OpenAI - get key from https://platform.openai.com
OPENAI_API_KEY=

# PostgreSQL (local dev - docker)
# docker run -d --name english-context-pg -e POSTGRES_USER=local -e POSTGRES_PASSWORD=local -e POSTGRES_DB=english_context -p 5432:5432 postgres:16
DATABASE_URL="postgresql://local:local@localhost:5432/english_context"

# For Vercel/Neon (production), set DATABASE_URL in Vercel dashboard
# .env.local gets populated by: vercel env pull
